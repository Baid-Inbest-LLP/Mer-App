NODE_ENV=development
PORT=5002
MONGODB_URI=mongodb://127.0.0.1:27017/mer_db
# Atlas example (include database name):
# MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/mer_db?retryWrites=true&w=majority
MONGODB_DB_NAME=mer_db
ADMIN_EMAIL=admin@mer.com
ADMIN_PASSWORD=admin123
USER_EMAIL=user@mer.com
USER_PASSWORD=user123
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_REFRESH_SECRET=your-refresh-secret-key-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
FRONTEND_URL=http://localhost:5174
UPLOAD_DIR=uploads
MAX_FILE_SIZE=5242880
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=MER System <noreply@mer.local>
